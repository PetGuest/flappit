# Copia este archivo como .env (o define las variables en tu proveedor de hosting)

# Puerto donde escucha el servidor
PORT=3000

# Cadena secreta larga y aleatoria para firmar las sesiones (¡cámbiala!)
SESSION_SECRET=pon-aqui-una-cadena-larga-y-aleatoria

# URL pública del servicio (para las redirecciones de Stripe)
BASE_URL=https://app.flapsapp.com

# --- Stripe (opcional: sin esto el servicio funciona en modo prueba) ---
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...   (del webhook que apunta a /api/stripe/webhook)
# STRIPE_PRICE_UNO_M=price_...   (plan 1 pantalla, mensual)
# STRIPE_PRICE_UNO_Y=price_...   (plan 1 pantalla, anual)
# STRIPE_PRICE_TRES_M=price_...  (plan 3 pantallas, mensual)
# STRIPE_PRICE_TRES_Y=price_...  (plan 3 pantallas, anual)

# --- Email SMTP (para "olvidé mi contraseña"; sin esto el enlace del panel
#     muestra el correo de contacto en lugar de enviar el email) ---
# Con DonDominio (buzón hello@flappit.com):
# SMTP_HOST=mailsrv1.dondominio.com
# SMTP_PORT=465
# SMTP_USER=hello@flappit.com
# SMTP_PASS=la-contraseña-del-buzón
# MAIL_FROM="Flappit" <hello@flappit.com>   (opcional; por defecto usa SMTP_USER)

# Email de la cuenta administradora (acceso a /admin; por defecto marcel@petguest.eu)
# ADMIN_EMAIL=marcel@petguest.eu

# Tamaño máximo de vídeo subido, en MB (por defecto 250)
# MEDIA_MAX_MB=250
# Carpeta donde se guardan los vídeos subidos (por defecto junto a la base de datos)
# MEDIA_DIR=/data/media
